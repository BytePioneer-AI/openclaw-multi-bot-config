{
  "dingtalk": {
    "requiredFields": ["clientId", "clientSecret"],
    "optionalFields": ["enabled", "enableAICard"],
    "supportsAccounts": true,
    "defaults": {
      "enabled": true,
      "enableAICard": false
    }
  },
  "qqbot": {
    "requiredFields": ["appId", "clientSecret"],
    "optionalFields": ["enabled", "sandbox"],
    "supportsAccounts": true,
    "defaults": {
      "enabled": true
    }
  },
  "wecom": {
    "requiredFields": ["webhookPath", "token", "encodingAESKey"],
    "optionalFields": ["enabled", "receiveId"],
    "supportsAccounts": true,
    "defaults": {
      "enabled": true
    }
  },
  "wecom-app": {
    "requiredFields": ["webhookPath", "token", "encodingAESKey", "corpId", "corpSecret", "agentId"],
    "optionalFields": ["enabled", "receiveId"],
    "supportsAccounts": true,
    "defaults": {
      "enabled": true
    }
  },
  "feishu-china": {
    "requiredFields": ["appId", "appSecret"],
    "optionalFields": ["enabled", "verificationToken"],
    "supportsAccounts": true,
    "defaults": {
      "enabled": true
    }
  }
}
