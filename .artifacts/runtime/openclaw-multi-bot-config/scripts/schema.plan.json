{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.dev/skills/openclaw-multi-bot-config/schema.plan.json",
  "title": "OpenClaw Bot Config Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "configPath", "summary", "resolved", "patch", "operations", "warnings", "errors"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "configPath": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "operation", "discoveredChannels", "channels", "agents", "bindings", "warnings"],
      "properties": {
        "action": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "discoveredChannels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "bindings": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "dmScope": {
          "type": ["string", "null"]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "resolved": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "operation", "discoveredChannels", "options", "targets", "agents", "bindings"],
      "properties": {
        "action": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "discoveredChannels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "options": {
          "type": "object"
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "bindings": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "dmScope": {
          "type": ["string", "null"]
        }
      }
    },
    "patch": {
      "type": "object",
      "additionalProperties": true
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target", "status", "reason"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["create", "update", "replace", "noop"]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
