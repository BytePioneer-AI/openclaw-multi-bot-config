{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.dev/skills/openclaw-multi-bot-config/schema.request.json",
  "title": "OpenClaw Bot Config Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "action", "configPath", "operation", "targets"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "action": {
      "type": "string",
      "enum": ["preview", "apply"]
    },
    "configPath": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": ["modify-existing-channel", "add-channel"]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "mode", "accounts"],
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["shared-agent", "isolated-agents", "hybrid"]
          },
          "defaultAccount": {
            "type": "string",
            "minLength": 1
          },
          "accounts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["accountId", "credentials"],
              "properties": {
                "accountId": {
                  "type": "string",
                  "minLength": 1
                },
                "credentials": {
                  "type": "object",
                  "minProperties": 1
                },
                "agentRef": {
                  "type": "string",
                  "minLength": 1
                },
                "enabled": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "default": {
            "type": "boolean"
          },
          "workspaceMode": {
            "type": "string",
            "enum": ["auto", "custom", "existing"]
          },
          "workspace": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sessionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["preserve", "recommended", "explicit"]
        },
        "dmScope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "createBackup": {
          "type": "boolean"
        },
        "preserveUnknownFields": {
          "type": "boolean"
        },
        "allowBindingOverride": {
          "type": "boolean"
        },
        "allowAgentWorkspaceReuse": {
          "type": "boolean"
        }
      }
    }
  }
}
