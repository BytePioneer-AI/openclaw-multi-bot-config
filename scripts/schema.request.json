{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.dev/skills/openclaw-multi-bot-config/schema.request.json",
  "title": "OpenClaw Minimal Config Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["configPath", "patch"],
  "properties": {
    "configPath": {
      "type": "string",
      "minLength": 1
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "agents": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "list": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": {
                    "type": "boolean"
                  },
                  "workspace": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "channels": {
          "type": "object",
          "description": "Raw channel nodes to merge into openclaw.json. Use the real OpenClaw field names here.",
          "additionalProperties": {
            "type": "object"
          }
        },
        "bindings": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "session": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dmScope": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
